# Local development secrets.
#
# Copy this file to .env (gitignored) and fill in real values:
#   cp .env.example .env
#   $EDITOR .env
#
# `just` recipes load this file automatically via `set dotenv-load`.

# Netbox local-dev API token.
# Created by the netbox-dev Ansible role on first apply; see logs for the token.
NETBOX_API_TOKEN=

# DigitalOcean API token (for `just lab-up`).
# Create at https://cloud.digitalocean.com/account/api/tokens with read+write scope.
DIGITALOCEAN_TOKEN=

# SSH key fingerprint registered with DigitalOcean (for Droplet provisioning).
# Get via: doctl compute ssh-key list
SSH_KEY_FINGERPRINT=
